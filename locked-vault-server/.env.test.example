# Dedicated database for integration tests.
# Copy this file to .env.test (gitignored) and fill in your values.
#
# Neon: create a separate branch (e.g. "test") and paste its connection string here.
# Local Postgres: create a database named lockprime_test and use that URL.

TEST_DATABASE_URL="postgresql://USER:PASSWORD@HOST/lockprime_test?sslmode=require"

# Optional emergency override — NOT recommended.
# Allows integration tests to wipe DATABASE_URL from .env instead of TEST_DATABASE_URL.
# ALLOW_DEV_DATABASE_TESTS=false
