# PostgreSQL connection string (Neon, local Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="replace-with-a-long-random-secret"

# API port (default: 5000)
PORT=5000

# Client app URL for password reset links and CORS
CLIENT_APP_URL="http://localhost:5173"

# Comma-separated allowed browser origins (optional — CLIENT_APP_URL is included automatically)
# CORS_ORIGINS="http://localhost:5173,https://lockprime.ca,https://www.lockprime.ca"

# Production security (defaults shown — HTTPS enforcement is on when NODE_ENV=production)
# NODE_ENV=production
# ENFORCE_HTTPS=true
# TRUST_PROXY=true
# RATE_LIMIT_ENABLED=true

# Email notifications for deposits, withdrawals, and vault unlocks (default on)
# NOTIFICATIONS_ENABLED=true

# Payment provider (default: simulated — instant in-process deposits/withdrawals)
PAYMENT_PROVIDER=simulated

# Optional: mark payments as stale for reconciliation after this many milliseconds
# STALE_PAYMENT_THRESHOLD_MS=86400000

# Resend (https://resend.com) — sends real password reset emails when set.
# Without RESEND_API_KEY, reset links are logged to the server console instead.
# Sandbox sender (onboarding@resend.dev) only delivers to your Resend account email.
# To email any user, verify a domain at resend.com/domains and update EMAIL_FROM.
RESEND_API_KEY="re_your_resend_api_key"

# Sender address — use onboarding@resend.dev for Resend sandbox/testing.
EMAIL_FROM="LockPrime <onboarding@resend.dev>"
